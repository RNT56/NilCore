{
  "request": {
    "method": "POST",
    "path": "/api/v1/chat/completions",
    "auth": "bearer:<redacted>",
    "referer": "https://nilcore.example",
    "title": "NilCore fixture",
    "body": {
      "model": "anthropic/claude-sonnet-4",
      "max_tokens": 512,
      "messages": [
        {
          "role": "system",
          "content": "You are a fixture."
        },
        {
          "role": "user",
          "content": "Return the fixture answer."
        }
      ],
      "provider": {
        "order": [
          "anthropic",
          "openai"
        ],
        "allow_fallbacks": false,
        "require_parameters": true,
        "data_collection": "deny",
        "zdr": true,
        "sort": "latency",
        "max_price": {
          "prompt": 1.25,
          "completion": 3.5
        }
      },
      "models": [
        "anthropic/claude-sonnet-4",
        "openai/gpt-5-mini"
      ],
      "reasoning": {
        "effort": "high",
        "exclude": true
      },
      "transforms": [
        "middle-out"
      ],
      "plugins": [
        {
          "id": "web",
          "max_results": 4,
          "engine": "exa"
        }
      ]
    }
  },
  "outcome": {
    "text": "routed",
    "stop_reason": "end_turn",
    "served_model": "openai/gpt-5-mini",
    "usage": {
      "input_tokens": 25,
      "output_tokens": 10,
      "cached_tokens": 8,
      "cost_usd": 0.0042
    },
    "content_types": [
      "text"
    ]
  }
}
