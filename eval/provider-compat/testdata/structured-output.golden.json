{
  "request": {
    "method": "POST",
    "path": "/v1/chat/completions",
    "auth": "bearer:<redacted>",
    "body": {
      "model": "gpt-4.1-mini",
      "max_tokens": 128,
      "messages": [
        {
          "role": "system",
          "content": "You are a fixture."
        },
        {
          "role": "user",
          "content": "Return the fixture answer."
        }
      ],
      "response_format": {
        "type": "json_schema",
        "json_schema": {
          "name": "fixture_answer",
          "strict": true,
          "schema": {
            "type": "object",
            "properties": {
              "answer": {
                "type": "string"
              }
            },
            "required": [
              "answer"
            ],
            "additionalProperties": false
          }
        }
      }
    }
  },
  "outcome": {
    "text": "{\"answer\":\"ready\"}",
    "stop_reason": "end_turn",
    "served_model": "gpt-4.1-mini",
    "usage": {
      "input_tokens": 16,
      "output_tokens": 6
    },
    "content_types": [
      "text"
    ]
  }
}
