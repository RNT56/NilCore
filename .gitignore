# Local env and secrets — never committed (invariant I3)
.env

# Append-only event log output
*.events.jsonl

# NilCore-local working state under a target repo (per-run, never committed):
# verified-artifact carriers and the per-run swarm collate roots (.nilcore/swarm/<runID>).
# Ignored so a stale RED artifact from a prior run can never be picked up by a fresh one
# and so the swarm never pollutes the persistent repo.
.nilcore/artifacts/
.nilcore/swarm/

# Built binaries
/nilcore
/cmd/nilcore/nilcore

# macOS
.DS_Store

# Local Claude Code session state (per-machine, not shared)
.claude/settings.local.json
.claude/scheduled_tasks.lock
/nilcore-browser
